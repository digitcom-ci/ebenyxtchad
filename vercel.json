{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://188.165.77.237:3000/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "http://188.165.77.237:3000/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
